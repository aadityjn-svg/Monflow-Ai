    "pino-pretty": "^13.1.1",
    "p-limit": "^6.2.0",
    "pino": "^9.9.0",
    "playwright": "^1.54.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
